
import java.util.Collections;
import java.util.List;
import java.util.Map;


 // Immutable snapshot of everything loaded from the repository.
// Domain layer — returned by TaskRepository.load() so that TaskSystem
// can populate its in-memory state in a single call.
 
public class RepositorySnapshot {

    private final List<Task> tasks;
    private final Map<String, String> projects;
    private final Map<String, Map<String, String>> collaboratorsByProject;

    public RepositorySnapshot(
        List<Task> tasks,
        Map<String, String> projects,
        Map<String, Map<String, String>> collaboratorsByProject
    ) {
        this.tasks                  = Collections.unmodifiableList(tasks);
        this.projects               = Collections.unmodifiableMap(projects);
        this.collaboratorsByProject = Collections.unmodifiableMap(collaboratorsByProject);
    }

    public List<Task> getTasks() {
        return tasks;
    }

    public Map<String, String> getProjects() {
        return projects;
    }

    public Map<String, Map<String, String>> getCollaboratorsByProject() {
        return collaboratorsByProject;
    }
}
