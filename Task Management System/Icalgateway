    // private method that maps a TaskSystem status string to the corresponding iCal STATUS property
     
      /* iCal "VEVENT" has 3 status values:
        Status.VEVENT_TENTATIVE  = not yet confirmed
        Status.VEVENT_CONFIRMED  = actively in progress
        Status.VEVENT_CANCELLED  =  done or closed
     */

     /* i think for the mapping this is fine:
      -"completed"/"closed"          → Status.VEVENT_CANCELLED
      -"in-progress"/"in progress"   → Status.VEVENT_CONFIRMED
      -anything else/"open"          → Status.VEVENT_TENTATIVE
      -null                          → return null (caller omits the property)
     */
    
    // Builds description field value for a VEVENT
    private String buildDescription(Task task) {
        StringBuilder sb = new StringBuilder();

        sb.append("Status: ").append(task.getStatus()).append("\n");
        sb.append("Priority: ").append(task.getPriority()).append("\n");

        if (!isBlank(task.getProjectName())) {
            sb.append("Project: ").append(task.getProjectName()).append("\n");
        }

        if (!isBlank(task.getDescription())) {
            sb.append("Description: ").append(task.getDescription()).append("\n");
        }

        if (!isBlank(task.getSubtask())) {
            sb.append("Subtasks:\n");
            String[] lines = task.getSubtask().split("\\r?\\n");
            for (String line : lines) {
                String trimmed = line.trim();
                if (!trimmed.isEmpty()) {
                    sb.append("  - ").append(trimmed).append("\n");
                }
            }
        }

        return sanitize(sb.toString().trim());
    }

  
     //Writes the Calendar to disk using the iCal4j CalendarOutputter

    private void writeTo(Calendar calendar, Path destinationPath)
            throws IOException, ValidationException {
        if (destinationPath.getParent() != null) {
            Files.createDirectories(destinationPath.getParent());
        }
        try (OutputStream out = new FileOutputStream(destinationPath.toFile())) {
            CalendarOutputter outputter = new CalendarOutputter();
            outputter.output(calendar, out);
        }
    }

     // Replaces literal newline characters with the iCal escaped sequence \n
     // according to iCal java libray, text values must escape newlines this way
    private String sanitize(String text) {
        if (text == null) return "";
        return text.replace("\r\n", "\\n").replace("\n", "\\n").replace("\r", "\\n");
    }

    private boolean isBlank(String value) {
        return value == null || value.trim().isEmpty();
    }
}
